RewriteEngine On

# Optional: Redirect HTTP to HTTPS, uncomment if needed
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Handle Directory Index
DirectoryIndex index.html

# Prevent directory listings
Options -Indexes

# Handle Authorizations
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle SPA exceptions
RewriteCond %{REQUEST_URI} !^/static
# Exclude .js files from SPA fallback
RewriteCond %{REQUEST_URI} !\.js$
# Exclude API calls from SPA fallback (for Bizzosa PHP APIs)
RewriteCond %{REQUEST_URI} !^/static/bizzosa/api/
# Handle SPA fallback
RewriteRule ^ index.html [L]

# API Routes for Bizzosa (clean URLs)
RewriteRule ^static/bizzosa/api/test/?$ static/bizzosa/api/test.php [L]
RewriteRule ^static/bizzosa/api/availability/?$ static/bizzosa/api/availability.php [L]
RewriteRule ^static/bizzosa/api/extras/?$ static/bizzosa/api/extras.php [L]
RewriteRule ^static/bizzosa/api/quote/?$ static/bizzosa/api/quote.php [L]
RewriteRule ^static/bizzosa/api/request-quote/?$ static/bizzosa/api/request_quote.php [L]